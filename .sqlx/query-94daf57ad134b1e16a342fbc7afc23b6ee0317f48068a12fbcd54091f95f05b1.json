  "query": "SELECT l.name, l.seller_address, l.price_sats, l.listed_at, l.inscription_utxo_sats,\n                (SELECT th.previous_price_sats FROM trade_history th WHERE th.name = l.name AND th.action IN ('buy_and_relist', 'relist') ORDER BY th.created_at DESC LIMIT 1) as previous_price_sats\n         FROM listings l ORDER BY l.listed_at DESC",
